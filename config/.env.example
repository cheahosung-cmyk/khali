# KIS(한국투자증권) OpenAPI 자격증명 — 이 파일을 .env로 복사 후 채우세요.
# .env는 절대 깃에 커밋하지 마세요 (.gitignore에 등록됨).

# KIS Developers 포털(https://apiportal.koreainvestment.com)에서 발급
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here

# 계좌번호: 앞 8자리 / 상품코드 뒤 2자리
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT=01

# true=모의투자(기본, 안전), false=실전투자. 실전은 충분한 검증 후에만!
KIS_IS_PAPER=true

# (선택) 알림용 텔레그램 봇
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
