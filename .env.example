# Khali LLM Council 설정 예시
# 이 파일을 복사해서 .env 로 만들고 실제 키를 넣으세요.
#   cp .env.example .env
#
# 키를 비워두면 해당 모델은 자동으로 mock(모의) 응답으로 동작합니다.
# 즉, 키 없이도 전체 흐름을 테스트할 수 있습니다.

# --- API 키 ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- 각 단계에 사용할 모델 (선택) ---
DRAFTER_MODEL=gpt-4o
SKEPTIC_MODEL=claude-opus-4-8
VERIFIER_MODEL=gemini-1.5-pro
SYNTHESIZER_MODEL=gpt-4o

# --- mock 강제 모드 (실제 키가 있어도 항상 모의 응답 사용) ---
# 1 / true / yes 로 켜집니다.
FORCE_MOCK=false
