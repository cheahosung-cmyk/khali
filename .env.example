# ── Khali Bithumb Auto-Trading: 환경설정 템플릿 ──
# 실제 키를 채운 뒤 이 파일을 .env 로 복사하세요. .env 는 절대 커밋되지 않습니다.
# cp .env.example .env

# ── 빗썸 API 2.0 키 (매매/조회 권한만, 출금 권한 제외!) ──
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

# ── 거래 모드: backtest | paper | live ──
# backtest = 과거데이터 검증, paper = 실시간 가상매매, live = 실제 주문
# live 로 바꾸기 전까지는 실제 돈이 절대 나가지 않습니다.
ORDER_MODE=paper

# ── 거래 대상 / 자본 ──
MARKET=KRW-XRP
BASE_CAPITAL_KRW=50000

# ── 사용할 전략 (registry 등록명) ──
# ma_crossover | rsi_reversion | volatility_breakout
STRATEGY=volatility_breakout

# 캔들 주기 (분봉): 1,3,5,10,15,30,60,240
CANDLE_UNIT=60

# ── 리스크 관리 (소액 자본 보수적 기본값) ──
# 거래당 진입 비중 (자본 대비, 0~1)
POSITION_SIZE_PCT=0.5
# 손절 % (진입가 대비 하락)
STOP_LOSS_PCT=0.02
# 익절 % (진입가 대비 상승)
TAKE_PROFIT_PCT=0.04
# 트레일링 스탑 % (고점 대비 하락 시 청산)
TRAILING_STOP_PCT=0.02
# 하루 최대 손실 한도 (자본 대비) - 초과 시 당일 매매 중단
DAILY_LOSS_LIMIT_PCT=0.1
# 연속 손실 N회 후 쿨다운 (회)
MAX_CONSECUTIVE_LOSSES=3
# 빗썸 최소 주문 금액 (KRW)
MIN_ORDER_KRW=5000
# 거래 수수료율 (빗썸 기본 0.04% ~ 0.25%, 보수적으로)
FEE_RATE=0.0025

# ── 엔진 ──
# 시세 폴링 주기 (초)
POLL_INTERVAL_SEC=10

# ── 웹 대시보드 ──
HOST=127.0.0.1
PORT=8000

# ── DB ──
DATABASE_URL=sqlite:///./data/khali.db

# ── (선택) 텔레그램 알림 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
