# ── Khali Bithumb Auto-Trading: 환경설정 템플릿 ──
# 실제 키를 채운 뒤 이 파일을 .env 로 복사하세요. .env 는 절대 커밋되지 않습니다.
# cp .env.example .env

# ── 빗썸 API 버전: 1 (Connect Key/HMAC-SHA512) | 2 (JWT) ──
API_VERSION=1

# ── 빗썸 API 키 (매매/조회 권한만, 출금 권한 제외!) ──
# API 1.0: Connect Key / Secret Key, API 2.0: Access Key / Secret Key
# (대시보드에서 직접 입력해 시작할 수도 있습니다. 비워두면 paper 모드로만 동작)
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

# ── 거래 모드: backtest | paper | live ──
# backtest = 과거데이터 검증, paper = 실시간 가상매매, live = 실제 주문
# live 로 바꾸기 전까지는 실제 돈이 절대 나가지 않습니다.
ORDER_MODE=paper

# ── 거래 대상 / 자본 ──
MARKET=KRW-XRP
BASE_CAPITAL_KRW=50000

# ── 사용할 전략 (registry 등록명) ──
# ma_crossover | rsi_reversion | volatility_breakout
STRATEGY=volatility_breakout

# 전략 파라미터 (JSON, 선택). `khali optimize` 로 찾은 값을 넣으세요.
# 예) ma_crossover  -> {"short": 15, "long": 100}
# 예) rsi_reversion -> {"period": 14, "oversold": 30}
STRATEGY_PARAMS=

# 캔들 주기 (분봉): 1,3,5,10,15,30,60,240 / 일봉=1440
CANDLE_UNIT=60

# 추세 필터: N봉 이동평균 위일 때만 신규 매수 (0=off)
# ⚠️ XRP 워크포워드 검증 결과 도움이 안 돼 기본 off. 다른 코인/구간에서만 실험적으로 사용.
TREND_FILTER_MA=0
# 백테스트 슬리피지(체결 불리 비율). 현실적 검증은 0.0005 권장, 0이면 무시.
SLIPPAGE_PCT=0.0

# ── 리스크 관리 (소액 자본 보수적 기본값) ──
# 거래당 진입 비중 (자본 대비, 0~1)
POSITION_SIZE_PCT=0.5
# 손절 % (진입가 대비 하락)
STOP_LOSS_PCT=0.02
# 익절 % (진입가 대비 상승)
TAKE_PROFIT_PCT=0.04
# 트레일링 스탑 % (고점 대비 하락 시 청산)
TRAILING_STOP_PCT=0.02
# 하루 최대 손실 한도 (자본 대비) - 초과 시 당일 매매 중단
DAILY_LOSS_LIMIT_PCT=0.1
# 연속 손실 N회 후 쿨다운 (회)
MAX_CONSECUTIVE_LOSSES=3
# 빗썸 최소 주문 금액 (KRW)
MIN_ORDER_KRW=5000
# 거래 수수료율 (빗썸 0.04%)
FEE_RATE=0.0004

# ── 엔진 ──
# 시세 폴링 주기 (초)
POLL_INTERVAL_SEC=10
# 엔진: single(단일코인 전략) | rotation(멀티코인 상대강도 자동 로테이션)
ENGINE=rotation
# 킬스위치: 평가자산이 고점 대비 이 비율 하락 시 전량청산+정지 (0=off, 예 0.25=-25%)
MAX_DRAWDOWN_STOP_PCT=0.25

# ── 로테이션 엔진 설정 ──
# lookback/rebalance 는 4구간 검증에서 robust(최악구간·중앙값·MDD 모두 최우수)한 값.
ROTATION_BASKET=BTC,ETH,XRP,SOL,ADA,DOGE,TRX,LINK
ROTATION_LOOKBACK=120
ROTATION_REBALANCE_DAYS=14
ROTATION_REGIME_MA=50

# ── 웹 대시보드 ──
HOST=127.0.0.1
PORT=8000

# ── DB ──
DATABASE_URL=sqlite:///./data/khali.db

# ── (선택) 텔레그램 알림 ──
# 설정 시 매수/매도/레짐전환/킬스위치/오류 발생 시 텔레그램으로 통지.
# 무인 24시간 가동 시 강력 권장. @BotFather로 봇 생성→토큰, 챗ID는 본인 채팅.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
